{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastPaste",
  "version": "2.2.0",
  "identifier": "com.xuan.fastpaste",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "FastPaste",
        "width": 960,
        "height": 720,
        "minWidth": 760,
        "minHeight": 560,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
